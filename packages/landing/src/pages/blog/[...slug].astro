---
import { getCollection, render } from "astro:content";
import { Footer } from "../../components/Footer";
import { Nav } from "../../components/Nav";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../globals.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - Lobu Blog`} description={post.data.description}>
  <div class="min-h-screen grid-lines" style={{ backgroundColor: "var(--color-page-bg)" }}>
    <Nav />
    <main class="relative z-[1]">
      <article class="max-w-3xl mx-auto px-6 pt-24 pb-12">
        <a href="/blog" class="text-sm text-page-text-muted hover:text-page-text transition-colors">&larr; Back to blog</a>
        <header class="mt-6 mb-10">
          <time class="text-sm text-page-text-muted">
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          <h1 class="text-4xl font-bold mt-2 text-page-text">{post.data.title}</h1>
          <p class="mt-2 text-page-text-muted">By {post.data.author}</p>
          {post.data.tags.length > 0 && (
            <div class="flex gap-2 mt-3">
              {post.data.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-full bg-page-surface text-page-text-muted border border-page-border">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>
        <div class="section-divider" />
        <div class="prose prose-invert max-w-none py-10 text-page-text [&_a]:text-tg-accent [&_h2]:text-page-text [&_h3]:text-page-text [&_strong]:text-page-text [&_code]:text-page-text">
          <Content />
        </div>
      </article>
    </main>
    <Footer />
  </div>
</BaseLayout>
